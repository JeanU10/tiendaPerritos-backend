{
  "containerDefinitions": [
    {
      "name": "back-container",
      "image": "022261932484.dkr.ecr.us-east-1.amazonaws.com/tienda-backend",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3001,
          "hostPort": 3001,
          "protocol": "tcp",
          "name": "back-container-3001-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_NAME",
          "value": "tienda_perritos"
        },
        {
          "name": "DB_HOST",
          "value": "10.0.2.19"
        },
        {
          "name": "DB_USER",
          "value": "alumno"
        },
        {
          "name": "DB_PASSWORD",
          "value": "alumno123"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/back-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "family": "back-task",
  "taskRoleArn": "arn:aws:iam::022261932484:role/LabRole",
  "executionRoleArn": "arn:aws:iam::022261932484:role/LabRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "3072"
}

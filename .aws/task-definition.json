{
  "containerDefinitions": [
    {
      "name": "backend-container",
      "image": "199014867669.dkr.ecr.us-east-1.amazonaws.com/tienda-backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "name": "backend-3000-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "DB_HOST", "value": "tienda-db-service.tienda-perritos.local" },
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_NAME", "value": "tienda_perritos" },
        { "name": "PORT", "value": "3000" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:ssm:us-east-1:199014867669:parameter/tienda/db/password" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tienda-backend-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "family": "tienda-backend-task",
  "taskRoleArn": "arn:aws:iam::199014867669:role/LabRole",
  "executionRoleArn": "arn:aws:iam::199014867669:role/LabRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
